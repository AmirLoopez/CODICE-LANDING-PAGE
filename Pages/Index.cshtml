                    <ul class="site-footer-links">
                        <li class="site-footer-link-item">
                            <a href="#section_1" class="site-footer-link">Home</a>
                        </li>

                        <li class="site-footer-link-item">
                            <a href="#section_2" class="site-footer-link">Acerca</a>
                        </li>

                        <li class="site-footer-link-item">
                            <a href="#section_4" class="site-footer-link">Horario</a>
                        </li>

                        <li class="site-footer-link-item">
                            <a href="#section_6" class="site-footer-link">Contacto</a>
                        </li>
                    </ul>
                </div>

                <div class="col-lg-3 col-md-6 col-12 mb-4 mb-lg-0">
                    <h5 class="site-footer-title mb-3">¿Tienes alguna pregunta?</h5>

                    <p class="text-white d-flex">
                        <a href="mailto:codice@uteq.edu.mx" class="site-footer-link">
                            codice@@uteq.edu.mx
                        </a>
                    </p>
                </div>

                <div class="col-lg-3 col-md-6 col-11 mb-4 mb-lg-0 mb-md-0">
                    <h5 class="site-footer-title mb-3">Ubicación</h5>

                    <p class="text-white d-flex mt-3 mb-2">
                        UTEQ, Santiago de Queretaro, Queretaro, Mexico</p>

                    <a class="link-fx-1 color-contrast-higher mt-3" href="#">
                        <span>Ver mapa</span>
