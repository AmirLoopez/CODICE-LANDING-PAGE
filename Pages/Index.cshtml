@page
@model IndexModel
@{
    Layout = null;
}
<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <meta name="description" content="">
    <meta name="author" content="">

    <title>CODICE 5.0 - Evento de Tecnologia 2026</title>

    <!-- CSS FILES -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;400;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="~/css/main-styles.css" rel="stylesheet">
</head>

<body data-bs-spy="scroll" data-bs-target=".navbar" data-bs-offset="100">

    <main>
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand">
                    <img src="~/img/logo_codice_O.png" alt="CODICE 5.0" height="80" />
                    <img src="~/img/logoUTEQ.png" class="logo-uteq-bg" alt="UTEQ" height="80" />
                    <img src="~/img/logoANAHUAC.png" alt="PIDET" height="80" />
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav align-items-lg-center ms-auto me-lg-5">
                        <li class="nav-item">
                            <a class="nav-link click-scroll" href="#section_1">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link click-scroll" href="#section_2">Acerca</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link click-scroll" href="#section_4">Horario</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link click-scroll" href="#section_6">Contacto</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>


        <section class="hero-section" id="section_1">
            <video class="hero-video" autoplay muted loop playsinline>
                <source src="~/img/films/globe_video.mp4" type="video/mp4">
            </video>
            <div class="section-overlay"></div>

            <div class="container d-flex justify-content-center align-items-center">
                <div class="row">

                    <div class="col-12 mt-auto mb-5 text-center">
                        <small>UTEQ presenta</small>

                        <h1 class="text-white mb-5">CODICE 5.0</h1>

                        <a class="btn custom-btn smoothscroll" href="#section_2">Comenzar</a>
                    </div>

                    <div class="col-lg-12 col-12 mt-auto d-flex flex-column flex-lg-row text-center">
                        <div class="date-wrap">
                            <h5 class="text-white">
                                <i class="custom-icon bi-clock me-2"></i>
                                23 - 25, Septiembre 2026
                            </h5>
                        </div>

                        <div class="location-wrap mx-auto py-3 py-lg-0">
                            <h5 class="text-white">
                                <i class="custom-icon bi-geo-alt me-2"></i>
                                UTEQ, Queretaro
                            </h5>
                        </div>
                    </div>
                </div>
            </div>
        </section>


        <section class="about-section section-padding" id="section_2">
            <div class="container">
                <div class="row">

                    <div class="col-lg-6 col-12 mb-4 mb-lg-0 d-flex align-items-center">
                        <div class="services-info">
                            <h2 class="text-white mb-4">Acerca de CODICE 5.0</h2>

                            <p class="text-white about-description">CÓDICE 2026 es el Congreso Internacional de Operaciones, Datos, Inteligencia, Ciberseguridad y Entornos Digitales. Este encuentro se consolida como el espacio cumbre en la región para conectar la vanguardia tecnológica con el sector productivo y académico, impulsando la evolución hacia la Industria 5.0.
                                                El congreso está diseñado para investigadores, profesionales, estudiantes y líderes de la industria interesados en las tecnologías disruptivas que están transformando los procesos industriales, la gestión de datos y la seguridad digital.</p>

                            <h6 class="text-white mt-4">¿Qué encontrarás?</h6>

                            <p class="text-white about-description">En este evento encontrarás una robusta agenda que incluye conferencias magistrales con líderes globales, más de 20 ponencias técnicas simultáneas impartidas por expertos de industrias clave, talleres prácticos intensivos en los laboratorios PIDET y CIC 4.0, paneles de debate de alto nivel con rectores de las principales universidades de la región, y un concurso de pósters científicos para interactuar directamente con investigadores de vanguardia.</p>

                            <h6 class="text-white mt-4">¿Para quién es?</h6>

                            <p class="text-white">Estudiantes, docentes, egresados y profesionistas que buscan aprender, conectar y colaborar.</p>
                        </div>
                    </div>

                    <div class="col-lg-6 col-12 about-image-column">
                        <div class="about-text-wrap">

                            <img src="~/img/Code.jpg" class="about-image img-fluid" alt="Comunidad CODICE 5.0">

                            <div class="about-text-info d-flex">
                                <div class="d-flex">
                                    <i class="about-text-icon bi-person"></i>
                                </div>

                                <div class="ms-4">
                                    <h3>3 dias</h3>
                                    <p class="mb-0 text-white">+20 actividades académicas</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <section class="schedule-section section-padding" id="section_4">
            <div class="container">
                <div class="row">

                    <div class="col-12 text-center">
                        <div class="text-color-primary mb-2">
                            <h2 class="mb-4 text-white">Horario del Evento Proximamente</h2>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>


    <footer class="site-footer">
        <div class="site-footer-top">
            <div class="container">
                <div class="row">

                    <div class="col-lg-6 col-12">
                        <h2 class="text-white mb-lg-0">CODICE 5.0</h2>
                    </div>

                    <div class="col-lg-6 col-12 d-flex justify-content-lg-end align-items-center">
                        <ul class="social-icon d-flex justify-content-lg-end">
                        
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="container">
            <div class="row">

                <div class="col-lg-6 col-12 mb-4 pb-2">
